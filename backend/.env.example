# Copy this file to ".env" and fill in your values.
# Environment variables used by the backend application.

# MongoDB connection string (e.g. mongodb://user:pass@host:port/dbname)
MONGO_URI=

# Email account settings used by nodemailer
EMAIL_USER=youremail@gmail.com
EMAIL_PASSWORD=yourpassword_or_app_specific_password

# Server port (optional, defaults may be handled in code)
PORT=3000
